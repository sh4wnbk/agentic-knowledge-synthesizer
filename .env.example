# IBM watsonx Credentials
# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSON_STT_API_KEY=your_watson_speech_to_text_api_key_here
WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com
WATSON_TTS_API_KEY=your_watson_text_to_speech_api_key_here
WATSON_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# Optional IBM Granite Guardian moderation
USE_GRANITE_GUARDIAN=false
GRANITE_GUARDIAN_MODEL=ibm/granite-guardian-3-8b
GRANITE_GUARDIAN_THRESHOLD=0.5

# Optional deployment overrides
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_db
CDC_SVI_CSV=./data/svi_2022_us_tract.csv
POLICY_DOCS_DIR=./data/policy_docs
